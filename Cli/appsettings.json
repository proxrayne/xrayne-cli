{
  "Serilog": {
    "Using": ["Serilog.Sinks.File", "Serilog.Sinks.Map"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [],
    "Enrich": ["FromLogContext"]
  },
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=5432;Username=postgres;Password=postgres;Database=xrayne"
  },
  "Jwt": {
    "Issuer": "XRayne",
    "Audience": "XRayne",
    "Secret": "change-this-development-secret-with-at-least-32-characters",
    "AccessTokenLifetimeMinutes": 60
  },
  "Xray": {
    "Directory": "../shared/",
    "FileName": "windows_amd64.dll"
  }
}
